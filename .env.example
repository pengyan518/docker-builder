# Copy to .env and fill in values (never commit .env).

# Hugging Face (required for scripts/upload_models_to_volume.sh downloads)
HF_TOKEN=hf_your_token_here

# RunPod Network Volume — S3 API (from RunPod dashboard)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT=https://s3api-us-il-1.runpod.io
AWS_BUCKET=
# Region shown in RunPod S3 examples (e.g. us-il-1)
AWS_REGION=us-il-1

# Optional: pull LoRA from Cloudflare R2 during upload script
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=
# R2_BUCKET_NAME=
# R2_LORA_KEY=models/lora/lora_Flux_Dev_4-step.safetensors

# Docker / deploy (scripts/deploy_runpod.sh)
# DOCKER_PASSWORD=
# RUNPOD_API_KEY=
